{
  "name": "dicd-elearning-spa",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler dev api/index.ts --local --port 8787",
    "build": "tsc && vite build",
    "build:api": "wrangler deploy api/index.ts",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist --project-name dicd-elearning",
    "db:migrate:local": "wrangler d1 migrations apply dicd-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply dicd-production",
    "db:seed": "wrangler d1 execute dicd-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "hono": "^4.11.1",
    "@cloudflare/workers-types": "^4.20250705.0",
    "wrangler": "^4.4.0"
  }
}
